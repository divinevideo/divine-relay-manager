# Divine Relay Manager - Production Build Environment
# Committed to repo - these are non-secret URL values.
# CF Access credentials (VITE_CF_ACCESS_CLIENT_ID, VITE_CF_ACCESS_CLIENT_SECRET)
# are NOT here - set them in .env.local or Cloudflare Pages project settings.

VITE_PROD_RELAY_URL=wss://relay.divine.video
VITE_PROD_API_URL=https://api-relay-prod.divine.video
VITE_STAGING_RELAY_URL=wss://relay.staging.divine.video
VITE_STAGING_API_URL=https://api-relay-staging.divine.video
