# Divine Relay Manager - Environment Variables
# Copy to .env.local for local development (.env.local is gitignored)
#
# Production/staging relay URLs are committed in .env.production (non-secret).
# Only CF Access credentials need to be set here for deploys to work.

# ============================================================================
# CF Access service token - required for the frontend to reach CF Access-protected
# API endpoints (api-relay-prod.divine.video, api-relay-staging.divine.video).
# Get these from the Cloudflare Zero Trust dashboard > Access > Service Tokens.
# ============================================================================
VITE_CF_ACCESS_CLIENT_ID=your-client-id.access
VITE_CF_ACCESS_CLIENT_SECRET=your-client-secret

# ============================================================================
# Local development overrides (optional)
# ============================================================================
VITE_LOCAL_RELAY_URL=wss://localhost:4443
VITE_LOCAL_API_URL=https://localhost:8788

# ============================================================================
# Worker variables are configured in worker/wrangler.toml or Cloudflare dashboard
# ============================================================================
